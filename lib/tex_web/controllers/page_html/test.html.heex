<div class="max-w-lg">
  <.header>
    page#test

    <:subtitle>Use this form to manage test records in your database.</:subtitle>

    <:actions>
      <.link href={~p"/test"}><.button class="btn-sm">Test</.button></.link>
    </:actions>
  </.header>

  <.test_form changeset={@changeset} action={~p"/test"} />

  <div class="my-10">
    <.list>
      <:item :for={x <- 1..3}  title={"title#{x}"}>value<%= x %></:item>
    </.list>
  </div>

  <.table id="tests" rows={@tests} row_click={&JS.navigate(~p"/test?#{&1.attr1}")}>
    <:col :let={test} label="Attr1"><%= test.attr1 %></:col>
    <:col :let={test} label="Attr2"><%= test.attr2 %></:col>
    <:col :let={test} label="Attr3"><%= test.attr3 %></:col>

    <:action :let={test}>
      <.link navigate={~p"/test"}>Edit</.link>
    </:action>

    <:action :let={test}>
      <.link href={~p"/test"} method="delete" data-confirm="Are you sure?">
        Delete
      </.link>
    </:action>
  </.table>
</div>

<button class="btn" onclick="my_modal_1.showModal()">open modal</button>

<.dialog id="my_modal_1" width_class="w-11/12 max-w-5xl">
  <h3 class="font-bold text-lg">Hello!</h3>
  <p class="py-4">Press ESC key or click the button to close</p>
</.dialog>

<.back navigate={~p"/test"}>Back to test</.back>
